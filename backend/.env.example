# Database
POSTGRES_USER=fincontrol
POSTGRES_PASSWORD=fincontrol_secret
POSTGRES_DB=fincontrol
POSTGRES_HOST=db
POSTGRES_PORT=5432
DATABASE_URL=postgresql://fincontrol:fincontrol_secret@db:5432/fincontrol

# Security
SECRET_KEY=change-this-to-a-long-random-string-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Login PIN (4 numeric digits)
APP_PIN=1234

# CORS
BACKEND_CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]
